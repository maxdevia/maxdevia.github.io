<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Max Devia — AI Projects</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --black: #0a0a0a;
      --white: #f5f0e8;
      --yellow: #f7e000;
      --orange: #ff4d00;
      --teal: #00e5c8;
      --red: #ff1744;
      --grid: rgba(245,240,232,0.04);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      background: var(--black);
      color: var(--white);
      font-family: 'DM Sans', sans-serif;
      overflow-x: hidden;
    }

    /* GRID OVERLAY */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(var(--grid) 1px, transparent 1px),
        linear-gradient(90deg, var(--grid) 1px, transparent 1px);
      background-size: 60px 60px;
      pointer-events: none;
      z-index: 0;
    }

    /* ─── NAV ─── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.2rem 3rem;
      background: rgba(10,10,10,0.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(245,240,232,0.08);
    }

    .nav-logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.6rem;
      letter-spacing: 0.05em;
      color: var(--yellow);
    }

    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }

    .nav-links a {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.75rem;
      color: var(--white);
      text-decoration: none;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      opacity: 0.7;
      transition: opacity 0.2s, color 0.2s;
    }

    .nav-links a:hover { opacity: 1; color: var(--yellow); }

    /* ─── HERO ─── */
    .hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 0 3rem;
      padding-top: 80px;
      overflow: hidden;
      z-index: 1;
    }

    .hero-eyebrow {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.8rem;
      letter-spacing: 0.2em;
      color: var(--teal);
      text-transform: uppercase;
      margin-bottom: 1.5rem;
      opacity: 0;
      animation: fadeUp 0.6s 0.2s forwards;
    }

    .hero-name {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(5rem, 14vw, 14rem);
      line-height: 0.88;
      letter-spacing: -0.01em;
      opacity: 0;
      animation: fadeUp 0.7s 0.35s forwards;
    }

    .hero-name span { color: var(--yellow); }

    .hero-subtitle {
      font-size: clamp(1rem, 2vw, 1.4rem);
      font-weight: 300;
      max-width: 520px;
      line-height: 1.6;
      margin-top: 2rem;
      opacity: 0;
      animation: fadeUp 0.7s 0.5s forwards;
      color: rgba(245,240,232,0.75);
    }

    .hero-cta {
      display: flex;
      gap: 1rem;
      margin-top: 3rem;
      opacity: 0;
      animation: fadeUp 0.7s 0.65s forwards;
    }

    .btn {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.8rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      text-decoration: none;
      padding: 0.9rem 2rem;
      border: none;
      cursor: pointer;
      transition: transform 0.15s, box-shadow 0.15s;
    }

    .btn:hover { transform: translateY(-2px); }

    .btn-primary {
      background: var(--yellow);
      color: var(--black);
      font-weight: 700;
      box-shadow: 4px 4px 0 var(--orange);
    }

    .btn-primary:hover { box-shadow: 6px 6px 0 var(--orange); }

    .btn-outline {
      background: transparent;
      color: var(--white);
      border: 1px solid rgba(245,240,232,0.3);
    }

    .btn-outline:hover { border-color: var(--teal); color: var(--teal); }

    /* BIG BACKGROUND TEXT */
    .hero-bg-text {
      position: absolute;
      bottom: -2rem;
      right: -1rem;
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(8rem, 22vw, 22rem);
      color: rgba(247,224,0,0.04);
      line-height: 1;
      pointer-events: none;
      user-select: none;
      white-space: nowrap;
    }

    /* ─── SECTION SHARED ─── */
    section {
      position: relative;
      z-index: 1;
      padding: 6rem 3rem;
    }

    .section-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.75rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--orange);
      margin-bottom: 1rem;
    }

    .section-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(3rem, 6vw, 5.5rem);
      line-height: 1;
      margin-bottom: 3rem;
    }

    /* ─── ABOUT STRIP ─── */
    .about-strip {
      background: var(--yellow);
      color: var(--black);
      padding: 3rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: center;
      border-top: 4px solid var(--orange);
      border-bottom: 4px solid var(--orange);
    }

    .about-strip h2 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2.5rem, 5vw, 4rem);
      line-height: 1.05;
      color: var(--black);
    }

    .about-strip p {
      font-size: 1.05rem;
      line-height: 1.7;
      font-weight: 400;
      color: rgba(10,10,10,0.8);
    }

    .about-strip strong { color: var(--black); }

    /* ─── PROJECTS GRID ─── */
    .projects-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
      gap: 1.5px;
      background: rgba(245,240,232,0.06);
      border: 1.5px solid rgba(245,240,232,0.06);
    }

    .project-card {
      background: var(--black);
      padding: 2.5rem;
      position: relative;
      overflow: hidden;
      transition: background 0.25s;
      cursor: default;
    }

    .project-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 3px;
      height: 100%;
      background: var(--card-accent, var(--yellow));
      transition: width 0.25s;
    }

    .project-card:hover { background: rgba(245,240,232,0.03); }
    .project-card:hover::before { width: 6px; }

    .project-tag {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--card-accent, var(--yellow));
      margin-bottom: 1rem;
    }

    .project-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2rem;
      letter-spacing: 0.02em;
      margin-bottom: 0.8rem;
      line-height: 1.1;
    }

    .project-desc {
      font-size: 0.9rem;
      line-height: 1.65;
      color: rgba(245,240,232,0.65);
      font-weight: 300;
    }

    .project-stack {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 1.5rem;
    }

    .stack-pill {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.65rem;
      padding: 0.3rem 0.7rem;
      background: rgba(245,240,232,0.06);
      border: 1px solid rgba(245,240,232,0.1);
      letter-spacing: 0.05em;
      color: rgba(245,240,232,0.5);
    }

    /* ─── CATEGORIES ─── */
    .categories {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 1rem;
      margin-bottom: 3rem;
    }

    .cat-btn {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.72rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.8rem 1.2rem;
      background: transparent;
      border: 1px solid rgba(245,240,232,0.15);
      color: rgba(245,240,232,0.5);
      cursor: pointer;
      transition: all 0.2s;
    }

    .cat-btn:hover, .cat-btn.active {
      border-color: var(--yellow);
      color: var(--yellow);
      background: rgba(247,224,0,0.05);
    }

    /* ─── CONTACT ─── */
    .contact-section {
      background: var(--orange);
      color: var(--black);
      padding: 5rem 3rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: center;
    }

    .contact-section h2 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(3rem, 6vw, 5.5rem);
      line-height: 1;
      color: var(--black);
    }

    .contact-section p {
      font-size: 1rem;
      line-height: 1.7;
      color: rgba(10,10,10,0.75);
      margin-bottom: 2rem;
    }

    .contact-links {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .contact-link {
      display: flex;
      align-items: center;
      gap: 1rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.85rem;
      color: var(--black);
      text-decoration: none;
      font-weight: 700;
      border-bottom: 2px solid rgba(10,10,10,0.2);
      padding-bottom: 1rem;
      transition: border-color 0.2s;
    }

    .contact-link:hover { border-color: var(--black); }

    .contact-link span { opacity: 0.5; font-weight: 400; }

    /* ─── FOOTER ─── */
    footer {
      padding: 2rem 3rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-top: 1px solid rgba(245,240,232,0.06);
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      color: rgba(245,240,232,0.25);
      letter-spacing: 0.08em;
      z-index: 1;
      position: relative;
    }

    /* ─── TICKER ─── */
    .ticker-wrap {
      overflow: hidden;
      border-top: 1px solid rgba(245,240,232,0.08);
      border-bottom: 1px solid rgba(245,240,232,0.08);
      padding: 0.8rem 0;
      background: rgba(255,77,0,0.06);
      position: relative;
      z-index: 1;
    }

    .ticker {
      display: flex;
      white-space: nowrap;
      animation: ticker 22s linear infinite;
    }

    .ticker-item {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.1rem;
      letter-spacing: 0.08em;
      color: rgba(245,240,232,0.3);
      padding: 0 2.5rem;
    }

    .ticker-item strong { color: var(--orange); }

    /* ─── ANIMATIONS ─── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(30px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    @keyframes ticker {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 768px) {
      nav { padding: 1rem 1.5rem; }
      .nav-links { display: none; }
      section { padding: 4rem 1.5rem; }
      .hero { padding: 0 1.5rem; padding-top: 70px; }
      .about-strip { grid-template-columns: 1fr; padding: 2rem 1.5rem; }
      .contact-section { grid-template-columns: 1fr; padding: 3rem 1.5rem; }
      footer { padding: 1.5rem; flex-direction: column; gap: 0.5rem; text-align: center; }
    }
  </style>
</head>
<body>

